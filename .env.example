# Existing YouTube integration
YOUTUBE_API_KEY=your_youtube_api_key

# Clip generation backend (required)
CLIP_BACKEND_URL=http://127.0.0.1:8000

# Optional: extra backends for automatic failover (comma or space separated)
CLIP_BACKEND_FALLBACK_URLS=

# Optional: total backend attempts per request (default: 3)
CLIP_BACKEND_MAX_ATTEMPTS=3

# Optional yt-dlp auth/runtime hints (used by backend/downloader services)
YTDLP_COOKIES_B64=
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_COOKIES_FILE=
YTDLP_JS_RUNTIMES=node
YTDLP_EXTRACTOR_ARGS=

# TikTok Login Kit + Content Posting API
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3000/api/tiktok/callback

# Optional override. Defaults to user.info.basic,video.publish
TIKTOK_SCOPE=user.info.basic,video.publish

# Used to encrypt secure TikTok session cookies (min 16 chars)
TIKTOK_SESSION_SECRET=replace_with_a_long_random_secret
